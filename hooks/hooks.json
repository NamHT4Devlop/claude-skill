{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/git-guard.sh",
            "timeout": 10,
            "statusMessage": "git-guard"
          }
        ]
      }
    ]
  }
}
